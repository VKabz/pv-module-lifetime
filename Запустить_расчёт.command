#!/bin/bash
# =====================================================================
#  Запуск расчёта срока службы фотоэлектрического модуля (macOS).
#  Просто дважды кликните по этому файлу в Finder.
#
#  При первом запуске скрипт сам создаст окружение Python и установит
#  все библиотеки — это займёт пару минут. Последующие запуски — мгновенно.
# =====================================================================

# Переходим в папку, где лежит этот файл
cd "$(dirname "$0")" || exit 1

echo "======================================================================"
echo "  Расчёт срока службы фотоэлектрического модуля"
echo "======================================================================"
echo ""

# Проверяем, установлен ли Python 3
if ! command -v python3 >/dev/null 2>&1; then
    echo "ОШИБКА: Python 3 не найден."
    echo "Установите Python с сайта https://www.python.org/downloads/"
    echo ""
    read -n 1 -s -r -p "Нажмите любую клавишу для выхода..."
    exit 1
fi

# Создаём виртуальное окружение при первом запуске
if [ ! -d ".venv" ]; then
    echo "Первый запуск: создаю окружение Python и устанавливаю библиотеки..."
    echo "(это займёт 1-2 минуты, нужен интернет)"
    echo ""
    python3 -m venv .venv
    ./.venv/bin/pip install --quiet --upgrade pip
    ./.venv/bin/pip install --quiet -r requirements.txt
    echo "Окружение готово."
    echo ""
fi

# Запускаем расчёт
echo "Выполняю расчёт..."
echo ""
./.venv/bin/python main.py

# Открываем папку с результатами
echo ""
echo "Открываю папку с графиками и таблицами..."
open output

echo ""
echo "======================================================================"
echo "  Готово. Графики и таблицы — в папке output/"
echo "======================================================================"
echo ""
read -n 1 -s -r -p "Нажмите любую клавишу, чтобы закрыть это окно..."
